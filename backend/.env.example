# Local development only — copy to .env (never commit .env)
# Production: set these in Render/Railway dashboard instead

DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/neondb?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=720
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
PKR_PER_RIYAL=75
STRAIGHT_PRIZE_MULTIPLIER=400
RUMBLE_PRIZE_MULTIPLIER=80
ENVIRONMENT=development
APP_PUBLIC_URL=
CORS_ORIGINS=
